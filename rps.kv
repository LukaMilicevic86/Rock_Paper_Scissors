#upper buttons template:
<RoundedButton@Button>
    background_color: (0, 0, 0, 0)
    canvas.before:
        Color:
            rgba: (29/255, 100/255, 25/255, 1)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [10]

#upper part:
<TheGame>
    size: root.width, root.height

    Label:
        id: instructions
        text:'Click on a pic'
        size_hint: 0.8, 0.1
        pos_hint: {'top': 1, 'right': 0.8}

    RoundedButton:
        text:'New'
        size_hint: 0.1, 0.08
        pos_hint: {'top': 1, 'right': 0.9}
        on_press: root.restart()
    
    RoundedButton:
        text:'Exit'
        size_hint: 0.1, 0.08
        pos_hint: {'top': 1, 'right': 1}
        on_press: app.stop()

#second row:

    Button:
        background_normal: 'rps/stone.png'
        size_hint: 0.2, 0.2
        pos_hint: {'x': 0.1, 'top': 0.9}
        on_press: root.rock()

    Button:
        background_normal: 'rps/paper.png'
        size_hint: 0.2, 0.2
        pos_hint: {'x': 0.4, 'top': 0.9}
        on_press: root.paper()

    Button:
        background_normal: 'rps/scissors.png'
        size_hint: 0.2, 0.2
        pos_hint: {'x': 0.7, 'top': 0.9}
        on_press: root.scissors()

#My and opponent points section:

    Label:
        text:'Your points'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.1, 'top': 0.6}

    Label:
        id: label_your_points
        text:'0'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.1, 'top': 0.5}
    
    Label:
        text:'Opponent points'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.1, 'top': 0.3}
    
    Label:
        id: label_opponent_points
        text:'0'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.1, 'top': 0.2}

#Game counter and selection display elements

    Label:
        text:'Game'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.4, 'top': 0.5}

    Label:
        id: game_number
        text:'0'
        size_hint: 0.2, 0.1
        pos_hint: {'x': 0.6, 'top': 0.5}

    Button:
        id: your_selection
        background_normal: 'rps/empty.png'
        size_hint: 0.2, 0.2
        pos_hint: {'x': 0.4, 'top': 0.9}

    Button:
        id: opponent_selection
        background_normal: 'rps/empty.png'
        size_hint: 0.2, 0.2
        pos_hint: {'x': 0.7, 'top': 0.4}